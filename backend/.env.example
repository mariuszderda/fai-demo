# Anthropic API key for the real LLM integration; omit it to use the deterministic stub.
ANTHROPIC_API_KEY=

# Primary Anthropic model id used by the backend.
ANTHROPIC_MODEL=claude-sonnet-4-5

# AlienVault OTX API key; omit it to fall back to the local MISP JSON fixture.
OTX_API_KEY=

# Approval token TTL in seconds; use a short value for local demos.
APPROVAL_TTL_SECONDS=30

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

